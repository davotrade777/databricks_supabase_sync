# Copy to .env and set your credentials:  cp .env.example .env

# ── Active environment: qas | prd ──────────────────────────────
DATABRICKS_ENV=qas

# ── QAS (Personal Access Token auth) ──────────────────────────
DATABRICKS_QAS_HOST=
DATABRICKS_QAS_HTTP_PATH=/sql/1.0/warehouses/YOUR_WAREHOUSE_ID
# Get your token: Databricks → Settings → Developer → Access tokens
DATABRICKS_QAS_TOKEN=

# ── PRD (OAuth M2M — Service Principal auth) ──────────────────
DATABRICKS_PRD_HOST=
DATABRICKS_PRD_HTTP_PATH=/sql/1.0/warehouses/YOUR_WAREHOUSE_ID
DATABRICKS_PRD_CLIENT_ID=
DATABRICKS_PRD_CLIENT_SECRET=

# ── Supabase Configuration ────────────────────────────────────
# Option 1: REST API (recommended — bypasses IPv6/pooler issues)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: second Supabase (Lambda p. ej. supabase_profile=secondary)
# SUPABASE_SECONDARY_URL=
# SUPABASE_SECONDARY_SERVICE_ROLE_KEY=

# Option 2: Direct Postgres
# SUPABASE_DB_HOST=
# SUPABASE_DB_USER=
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_PORT=6543

# Option 3: Connection String
# SUPABASE_CONNECTION_STRING=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require

# ── Sync Configuration (optional) ─────────────────────────────
OVERLAP_DAYS=7
FETCH_SIZE=5000

# Optional: default table when running connector.py as script
# DBX_TABLE=qas.aplicaciones.transportistas_final
