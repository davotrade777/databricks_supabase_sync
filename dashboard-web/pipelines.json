{
  "transportistas": {
    "pipeline_name": "transportistas",
    "databricks_profile": "prd",
    "supabase_profile": "default",
    "row_mode": "transportistas",
    "source_table": "prod.gldlogistica.db_trade_dim_app_transportistas",
    "target_table": "transportistas",
    "write_mode": "insert_only",
    "conflict_key": "codigo_transportista",
    "batch_size": 500,
    "schedule": "cron(0 5 * * ? *)",
    "column_mapping": [
      { "source": "codigo_transportista", "target": "codigo_transportista" },
      { "source": "ruc", "target": "ruc" },
      { "source": "nombre_transportista", "target": "nombre_transportista" },
      { "source": "telefono", "target": "telefono" },
      { "source": "email", "target": "email" }
    ],
    "defaults": {
      "estado_transportista": "pendiente"
    },
    "id_strategy": {
      "column": "transportista_id",
      "type": "uuid5_codigo_transportista"
    }
  },
  "vehiculos": {
    "pipeline_name": "vehiculos",
    "databricks_profile": "qas",
    "supabase_profile": "secondary",
    "row_mode": "generic",
    "source_table": "qas.gldlogistica.db_trade_dim_vehiculos",
    "target_table": "vehicles",
    "write_mode": "insert_only",
    "conflict_key": "license_plate",
    "require_non_null": ["placa"],
    "batch_size": 500,
    "schedule": "manual",
    "column_mapping": [
      { "source": "placa", "target": "license_plate" },
      { "source": "tipo_trasporte", "target": "type" },
      { "source": "capacidad_ton", "target": "weight_average_capacity" },
      { "source": "codigo_transportista", "target": "fleet_owner_unique_code" },
      { "source": "flg_rutero", "target": "is_route_based" }
    ],
    "boolean_fields": ["is_route_based"],
    "defaults": {},
    "null_coalesce": {
      "weight_average_capacity": 0,
      "weight_average_capacity_unit": "TON",
      "fleet_owner_unique_code": ""
    },
    "id_strategy": {
      "type": "uuid5_from_source",
      "column": "id",
      "source_column": "placa",
      "namespace": "b8f9e3a1-7c2d-4f5e-9a1b-3c4d5e6f7a8b"
    },
    "include_ingested_at": true,
    "sync_timestamp_column": "synced_at",
    "datamart_timestamp_column": "synced_at"
  },
  "viajes": {
    "pipeline_name": "viajes",
    "databricks_profile": "qas",
    "supabase_profile": "secondary",
    "row_mode": "generic",
    "source_table": "qas.aplicaciones.fact_transportistas_viajes",
    "target_table": "ct_freights",
    "write_mode": "insert_only",
    "conflict_key": "id",
    "require_non_null": ["codigo_viaje"],
    "batch_size": 500,
    "schedule": "manual",
    "column_mapping": [
      { "source": "codigo_viaje", "target": "freight_code" },
      { "source": "fecha", "target": "assignment_date" },
      { "source": "codigo_unico_transportista", "target": "fleet_owner_unique_code" },
      { "source": "distancia_km", "target": "distance" },
      { "source": "placa", "target": "license_plate" },
      { "source": "peso_ton", "target": "weight" },
      { "source": "valor_neto", "target": "net_pay" }
    ],
    "id_strategy": {
      "type": "uuid5_from_source",
      "column": "id",
      "source_column": "codigo_viaje",
      "namespace": "b8f9e3a1-7c2d-4f5e-9a1b-3c4d5e6f7a8b"
    },
    "include_ingested_at": true,
    "sync_timestamp_column": "synced_at",
    "datamart_timestamp_column": "synced_at"
  }
}
